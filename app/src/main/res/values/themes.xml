<resources>
    <!-- Window theme only (Jetpack Compose draws the actual UI). Platform parent
         means no AppCompat / Material-View dependency is required. -->
    <style name="Theme.RiskScope" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/brand_bg_light</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
